{
  "terminal.integrated.defaultProfile.linux": "bash",
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "python.terminal.activateEnvironment": true,
  "python.terminal.activateEnvInCurrentTerminal": true,
  "python.languageServer": "Default",
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "flake8.args": [
    // E203,W503,W504はblack対応
    "--ignore=E501,F401,F541,F811,E203,W503,W504",
    "--max-line-length=88"
  ],
  "[pip-requirements]": {
    "files.encoding": "utf8",
    "files.eol": "\n"
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "todo-tree.general.tags": [
    "BUG",
    "HACK",
    "FIXME",
    "TODO",
    "XXX",
    "MEMO",
    "NOTE",
    "WARNING"
  ],
  "todo-tree.filtering.excludeGlobs": ["**/.venv", "**/static/vendor"],
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
  },
  "markdownlint.config": {
    "default": true, // すべてのルールを有効にする
    "MD018": false // 複数の空白を許可しないルールを無効にする
  },
  "[shellscript]": {
    "editor.codeActionsOnSave": {
      "source.fixAll.shellcheck": "explicit"
    }
  },
  "isort.args": ["--profile", "black"],
  "python.testing.pytestArgs": ["tests", "-s"],
  "python.testing.unittestEnabled": false,
  "python.testing.pytestEnabled": true
}
